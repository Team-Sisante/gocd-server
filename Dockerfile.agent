# Dockerfile.agent
# Used by gocd-agent-1 (pearl-hello-world) and gocd-agent-2 (badminton_court)
FROM gocd/gocd-agent-alpine:v25.4.0

USER root

# Install base dependencies
RUN apk add --no-cache ca-certificates openssl curl docker gnupg python3 bash gosu

# Install jq
RUN apk add --no-cache jq

# Install GitHub CLI (gh)
RUN apk add --no-cache git && \
    wget -O gh.tar.gz https://github.com/cli/cli/releases/download/v2.40.1/gh_2.40.1_linux_amd64.tar.gz && \
    tar -xzf gh.tar.gz && \
    mv gh_2.40.1_linux_amd64/bin/gh /usr/local/bin/ && \
    rm -rf gh_2.40.1_linux_amd64 gh.tar.gz

# Install docker-compose
RUN apk add --no-cache docker-compose

# Install Node.js
RUN apk add --no-cache nodejs npm

# Install Google Cloud SDK
RUN curl -sSL https://sdk.cloud.google.com > /tmp/gcloud-install.sh && \
    bash /tmp/gcloud-install.sh --install-dir=/usr/local --disable-prompts && \
    ln -s /usr/local/google-cloud-sdk/bin/gcloud /usr/local/bin/gcloud && \
    rm /tmp/gcloud-install.sh
ENV PATH $PATH:/usr/local/google-cloud-sdk/bin

# Set global environment variables for SSL/TLS
ENV SSL_CERT_FILE=/etc/ssl/certs/ca-certificates.crt \
    CURL_CA_BUNDLE=/etc/ssl/certs/ca-certificates.crt \
    REQUESTS_CA_BUNDLE=/etc/ssl/certs/ca-certificates.crt \
    CLOUDSDK_CORE_CUSTOM_CA_CERTS_FILE=/etc/ssl/certs/ca-certificates.crt

# Add entrypoint script
COPY Scripts/agent-entrypoint.sh /usr/local/bin/agent-entrypoint.sh
RUN chmod +x /usr/local/bin/agent-entrypoint.sh

ENTRYPOINT ["agent-entrypoint.sh"]
