<!-- config/cruise-config.xml -->
<cruise schemaVersion="139">
  <server agentAutoRegisterKey="default" serverId="__SERVER_ID__" tokenGenerationKey="__TOKEN_GENERATION_KEY__">
    <security>
      <authConfigs>
        <authConfig id="password_file" pluginId="cd.go.authentication.passwordfile">
          <property>
            <key>PasswordFilePath</key>
            <value>/godata/config/password.properties</value>
          </property>
        </authConfig>
      </authConfigs>
      <roles>
        <role name="gocd-system-administrators">
          <users>
            <user>admin</user>
          </users>
        </role>
      </roles>
      <admins>
        <user>admin</user>
      </admins>
    </security>
    <siteUrls>
      <siteUrl>__SITE_URL__</siteUrl>
    </siteUrls>
    <artifacts>
      <artifactsDir>artifacts</artifactsDir>
    </artifacts>
  </server>

  <!-- ============================================================ -->
  <!-- humrine_site pipelines                                       -->
  <!-- ============================================================ -->
  <pipelines group="humrine_site_group">
    <pipeline name="humrine_site-artifacts">
      <materials>
        <git url="__HUMRINE_SITE_REPO_URL_WITH_CREDENTIALS__" branch="master" dest="humrine_site" />
      </materials>
      <stage name="build_and_push">
        <approval type="manual" />
        <jobs>
          <job name="artifact_generation">
            <resources>
              <resource>docker</resource>
              <resource>humrine_site</resource>
            </resources>
            <tasks>
              <exec command="bash">
                <arg>-c</arg>
                <arg><![CDATA[
                  set -e
                  git config --global --add safe.directory /humrine_site
                  cd /humrine_site
                  npm ls axios >/dev/null 2>&1 || npm install axios
                  export GITHUB_TOKEN='__GITHUB_TOKEN__'
                  node Scripts/build-and-push.js
                  git rev-parse --short HEAD > /shared-tags/humrine_site-tag-${GO_PIPELINE_COUNTER}.txt
                ]]></arg>
              </exec>
            </tasks>
          </job>
        </jobs>
      </stage>
    </pipeline>

    <pipeline name="humrine_site-staging">
      <environmentvariables>
        <variable name="OVERRIDE_IMAGE_TAG">
          <value></value>
        </variable>
      </environmentvariables>
      <materials>
        <pipeline pipelineName="humrine_site-artifacts" stageName="build_and_push" />
      </materials>
      <stage name="deploy_staging">
        <approval type="manual" />
        <jobs>
          <job name="remote_deploy">
            <resources>
              <resource>docker</resource>
              <resource>humrine_site</resource>
            </resources>
            <tasks>
              <exec command="bash">
                <arg>-c</arg>
                <arg><![CDATA[
                  if [ -n "$OVERRIDE_IMAGE_TAG" ]; then
                    export IMAGE_TAG="$OVERRIDE_IMAGE_TAG"
                  else
                    export IMAGE_TAG=sha-$(cat /shared-tags/humrine_site-tag-${GO_DEPENDENCY_LABEL_HUMRINE_SITE_ARTIFACTS}.txt)
                  fi
                  echo "Deploying image tag: $IMAGE_TAG"
                  node /gocd-server/Scripts/deploy.js humrine_site staging __GITHUB_TOKEN__
                ]]></arg>
              </exec>
            </tasks>
          </job>
        </jobs>
      </stage>
    </pipeline>

    <pipeline name="humrine_site-production">
      <environmentvariables>
        <variable name="OVERRIDE_IMAGE_TAG">
          <value></value>
        </variable>
      </environmentvariables>
      <materials>
        <pipeline pipelineName="humrine_site-artifacts" stageName="build_and_push" />
      </materials>
      <stage name="deploy_production">
        <approval type="manual" />
        <jobs>
          <job name="remote_deploy">
            <resources>
              <resource>docker</resource>
              <resource>humrine_site</resource>
            </resources>
            <tasks>
              <exec command="bash">
                <arg>-c</arg>
                <arg><![CDATA[
                  if [ -n "$OVERRIDE_IMAGE_TAG" ]; then
                    export IMAGE_TAG="$OVERRIDE_IMAGE_TAG"
                  else
                    export IMAGE_TAG=sha-$(cat /shared-tags/humrine_site-tag-${GO_DEPENDENCY_LABEL_HUMRINE_SITE_ARTIFACTS}.txt)
                  fi
                  echo "Deploying image tag: $IMAGE_TAG"
                  node /gocd-server/Scripts/deploy.js humrine_site production __GITHUB_TOKEN__
                ]]></arg>
              </exec>
            </tasks>
          </job>
        </jobs>
      </stage>
    </pipeline>
  </pipelines>

