            <resources>
              <resource>docker</resource>
              <resource>pay-sol</resource>
            </resources>
            <tasks>
              <exec command="bash">
                <arg>-c</arg>
                <arg><![CDATA[
                  export GITHUB_TOKEN='__GITHUB_TOKEN__'
                  node /pay-sol/Scripts/build-and-push.js
